---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage frontmatter={{ title: 'Search', template: 'splash', pagefind: false }}>
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <div id="pagefind-search"></div>
  <script src="/pagefind/pagefind-ui.js" is:inline></script>
  <script is:inline>
    // `/pagefind/` assets are generated by `astro build` and are not present
    // during `astro dev`. Pagefind exposes `PagefindUI` as a global on load.
    window.addEventListener('DOMContentLoaded', () => {
      const MAX_ATTEMPTS = 40; // ~2s at 50ms intervals
      let attempts = 0;
      const renderFallback = (reason) => {
        console.error('PagefindUI unavailable:', reason);
        const el = document.getElementById('pagefind-search');
        if (el) {
          el.innerHTML =
            '<p>Search is currently unavailable. Please try again later or use the search button in the site header.</p>';
        }
      };
      const init = () => {
        try {
          if (typeof window.PagefindUI !== 'undefined') {
            new window.PagefindUI({
              element: '#pagefind-search',
              showSubResults: true,
              showImages: false,
            });
            return;
          }
        } catch (err) {
          renderFallback(err);
          return;
        }
        if (++attempts >= MAX_ATTEMPTS) {
          renderFallback('script did not load within ' + MAX_ATTEMPTS * 50 + 'ms');
          return;
        }
        setTimeout(init, 50);
      };
      init();
    });
  </script>
</StarlightPage>

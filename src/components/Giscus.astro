---
/**
 * Giscus comments component (GitHub Discussions-backed).
 *
 * Activation is gated behind PUBLIC_GISCUS_ENABLED. When the flag is unset or
 * not exactly "true", this component renders nothing -- safe to ship disabled.
 *
 * Config is read from PUBLIC_GISCUS_* env vars at build time (Astro inlines
 * PUBLIC_-prefixed vars into the client bundle). See docs/giscus-activation.md.
 *
 * Uses the official script-tag integration: giscus.app/client.js reads the
 * data-* attributes from its own <script> tag and injects the comments iframe
 * (rendered as .giscus / .giscus-frame, styled in giscus.css). The tag must be
 * `is:inline` so Astro emits it verbatim with the data-* attributes intact
 * instead of bundling it (which would strip the data-* config and break giscus).
 */
const enabled = import.meta.env.PUBLIC_GISCUS_ENABLED === 'true';

const repo = import.meta.env.PUBLIC_GISCUS_REPO ?? '';
const repoId = import.meta.env.PUBLIC_GISCUS_REPO_ID ?? '';
const category = import.meta.env.PUBLIC_GISCUS_CATEGORY ?? '';
const categoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID ?? '';

const allConfigured =
    enabled && repo && repoId && category && categoryId;
---

{
    allConfigured && (
        <div class="giscus-wrapper">
            <script
                src="https://giscus.app/client.js"
                data-repo={repo}
                data-repo-id={repoId}
                data-category={category}
                data-category-id={categoryId}
                data-mapping="pathname"
                data-strict="1"
                data-reactions-enabled="1"
                data-emit-metadata="0"
                data-input-position="bottom"
                data-theme="preferred_color_scheme"
                data-lang="en"
                data-loading="lazy"
                crossorigin="anonymous"
                is:inline
                async
            />
        </div>
    );
}

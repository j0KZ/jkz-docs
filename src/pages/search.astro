---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage frontmatter={{ title: 'Search', template: 'splash', pagefind: false }}>
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <div id="pagefind-search"></div>
  <script src="/pagefind/pagefind-ui.js" is:inline></script>
  <script is:inline>
    // `/pagefind/` assets are generated by `astro build` and are not present
    // during `astro dev`. Pagefind exposes `PagefindUI` as a global on load.
    window.addEventListener('DOMContentLoaded', () => {
      const init = () => {
        if (typeof window.PagefindUI !== 'undefined') {
          new window.PagefindUI({
            element: '#pagefind-search',
            showSubResults: true,
            showImages: false,
          });
        } else {
          setTimeout(init, 50);
        }
      };
      init();
    });
  </script>
</StarlightPage>
